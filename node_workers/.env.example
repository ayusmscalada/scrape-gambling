# Node Workers Environment Configuration
# Copy this file to .env and update with your actual values

# Express Server Configuration
PORT=3000
NODE_ENV=development

# PostgreSQL Connection (for local development)
# If running PostgreSQL in Docker, use localhost and the mapped port (5433)
# If running PostgreSQL locally, use localhost and your local port (usually 5432)
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=enrichment_db
POSTGRES_USER=enrichment_user
POSTGRES_PASSWORD=enrichment_pass

# PostgreSQL Sync Configuration
# Interval in milliseconds for auto-syncing usernames to PostgreSQL
POSTGRES_SYNC_INTERVAL_MS=30000

# Username API URL (for API client)
# Used by workers to send usernames to the storage API
USERNAME_API_URL=http://localhost:3000

# Puppeteer Configuration
# Browser cache directory (optional, defaults to ~/.cache/puppeteer)
PUPPETEER_CACHE_DIR=
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=false

# X11 Display (for visible browsers, optional)
DISPLAY=:0
